# Aplicação
APP_NAME=opiagile-ai-rag-core
APP_ENV=oracle-free-tier

# Domínio e proxy
# Sem domínio, mantenha CADDYFILE_PATH=./Caddyfile.http e acesse por http://IP_PUBLICO.
# Com domínio apontado, use CADDYFILE_PATH=./Caddyfile.https e preencha RAG_DOMAIN/ACME_EMAIL.
CADDYFILE_PATH=./Caddyfile.http
RAG_DOMAIN=
SITE_DOMAIN=opiagile.com
SITE_WWW_DOMAIN=www.opiagile.com
DEMO_RAG_DOMAIN=demo-rag.opiagile.com
ACME_EMAIL=

# PostgreSQL / pgvector
POSTGRES_DB=opiagile_ai_rag_core
POSTGRES_USER=opiagile
POSTGRES_PASSWORD=troque_esta_senha
FLYWAY_ENABLED=true

# Documentos e RAG
DOCUMENT_UPLOAD_MAX_BYTES=262144
DOCUMENT_UPLOAD_MAX_CHARS=200000
DOCUMENT_UPLOAD_MAX_CHUNKS=300
DOCUMENT_UPLOAD_MAX_DOCUMENTS=50
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=256KB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=300KB
DOCUMENT_CHUNK_MAX_CHARS=900
DOCUMENT_CHUNK_OVERLAP_CHARS=120
RAG_TOP_K=5
RAG_MIN_SCORE=0.15
CONVERSATION_HISTORY_LIMIT=8
TENANT_DEFAULT_TENANT=demo
TENANT_DEFAULT_WORKSPACE=clinica-demo
TOOLS_EXECUTION_REQUIRE_ADMIN_TOKEN=true
TOOLS_PLANNER_LLM_ENABLED=true
TOOLS_PLANNER_LLM_MAX_OUTPUT_TOKENS=120

# Chat público da landing Opiagile.
# Preencha SITE_CHAT_API_KEY fora do Git e use a mesma chave na aplicação da landing.
SITE_CHAT_ENABLED=true
SITE_CHAT_API_KEY=
SITE_CHAT_TENANT=opiagile
SITE_CHAT_WORKSPACE=opiagile-rag
SITE_CHAT_RATE_LIMIT_PER_MINUTE=20

# Proteção simples da demo pública. Preencha tokens fora do Git.
DEMO_ACCESS_TOKEN=
DEMO_ADMIN_TOKEN=
DEMO_RATE_LIMIT_ENABLED=true
DEMO_CHAT_RATE_LIMIT_PER_MINUTE=30
DEMO_UPLOAD_RATE_LIMIT_PER_MINUTE=5
CADDY_REQUEST_BODY_MAX_SIZE=300KB

# API keys tenant-aware.
# Cadastre clients em api_clients e use true depois que site/demo estiverem usando as chaves.
API_SECURITY_ENABLED=true
API_SECURITY_REQUIRE_API_KEY=true
API_SECURITY_DEFAULT_RATE_LIMIT_PER_MINUTE=60
OPIAGILE_SITE_RAG_CORE_API_KEY=
DEMO_RAG_CORE_API_KEY=
DEMO_RAG_CORE_API_KEY_CLINICA_DEMO=
DEMO_RAG_CORE_API_KEY_ATENDIMENTO_DEMO=
DEMO_RAG_CORE_API_KEY_LOCACAO_DEMO=

# Portal de desenvolvedores e OpenAPI.
OPENAPI_ENABLED=true
OPENAPI_UI_ENABLED=false

# Notificação de solicitações de API key sandbox.
# Para Microsoft 365, use smtp.office365.com:587 com STARTTLS e credenciais fora do Git.
DEVELOPER_ACCESS_EMAIL_ENABLED=false
DEVELOPER_ACCESS_EMAIL_TO=contato@opiagile.com
DEVELOPER_ACCESS_EMAIL_FROM=contato@opiagile.com
DEVELOPER_ACCESS_EMAIL_SUBJECT_PREFIX="[Opiagile] Solicitação de API key sandbox"
DEVELOPER_ACCESS_EMAIL_PUBLIC_BASE_URL=https://opiagile.com
DEVELOPER_ACCESS_KEY_DELIVERY_EXPIRES_IN_HOURS=24
SPRING_MAIL_HOST=smtp.office365.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_HEALTH_ENABLED=false
DEVELOPER_ACCESS_EMAIL_SCHEDULER_ENABLED=true
DEVELOPER_ACCESS_EMAIL_SCHEDULER_FIXED_DELAY_MS=60000
DEVELOPER_ACCESS_EMAIL_SCHEDULER_BATCH_SIZE=5
DEVELOPER_ACCESS_EMAIL_SCHEDULER_MAX_ATTEMPTS=10
DEVELOPER_ACCESS_EMAIL_SCHEDULER_RETRY_DELAY_MINUTES=15

# LLM e embeddings.
# Para teste sem custo externo, mantenha DEMO/false e deixe OPENAI_API_KEY vazia.
# Para RAG com LLM e embeddings reais, preencha OPENAI_API_KEY e ajuste os modos.
LLM_PROVIDER=DEMO
CHAT_RESPONSE_MODE=DEMO
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_CHAT_MODEL=gpt-5-mini
OPENAI_EMBEDDINGS_ENABLED=false
OPENAI_EMBEDDINGS_PROVIDER=manual
SPRING_AI_MODEL_CHAT=none
SPRING_AI_MODEL_EMBEDDING=none
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_MAX_OUTPUT_TOKENS=600
OPENAI_TIMEOUT_SECONDS=30
OPENAI_REASONING_EFFORT=minimal
OPENAI_TEXT_VERBOSITY=low
CHAT_SYSTEM_TONE="profissional, claro, acolhedor e objetivo"

# Langfuse opcional
LANGFUSE_ENABLED=false
LANGFUSE_HOST=
